server:
  port: 8080
  mode: debug  # debug or release
  static_path: ./static

database:
  path: ./data/atlas.db

scheduler:
  scan_interval: 5  # seconds

security:
  shared_secret: "change-this-secret-in-production"
  jwt_secret: "change-this-jwt-secret-in-production"
  admin_password: "change-me"
